{
  "name": "@teaching/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply teaching-db --local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@teaching/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@types/js-yaml": "^4.0.9",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
